{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Crucible.slnx",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/Crucible.slnx",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/Crucible.slnx"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "aspire resource rebuild",
            "type": "shell",
            "command": "aspire",
            "args": [
                "resource",
                "${input:aspireResource}",
                "rebuild"
            ],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "aspireResource",
            "type": "pickString",
            "description": "Select the resource to rebuild",
            "options": [
                "player-api",
                "player-vm-api",
                "caster-api",
                "alloy-api",
                "topomojo",
                "steamfitter-api",
                "cite-api",
                "gallery-api",
                "blueprint-api",
                "gameboard"
            ]
        }
    ]
}