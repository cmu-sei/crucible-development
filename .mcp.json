{
  "mcpServers": {
    "aspire": {
      "command": "aspire",
      "args": [
        "mcp",
        "start"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "playwright-test": {
      "command": "/mnt/data/crucible/crucible-tests/node_modules/.bin/playwright",
      "args": [
        "run-test-mcp-server",
        "--config",
        "/mnt/data/crucible/crucible-tests/playwright.config.ts"
      ],
      "cwd": "/mnt/data/crucible/crucible-tests"
    }
  }
}
