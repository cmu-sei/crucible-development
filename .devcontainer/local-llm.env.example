# Local LLM Provider Configuration
# Copy this file to local-llm.env and fill in your values.
# This file is loaded as container environment variables at startup.

# Base URL for your OpenAI-compatible LLM endpoint
LOCAL_LLM_BASE_URL=https://your-llm-endpoint.example.com/api

# API key for your LLM provider
LOCAL_LLM_API_KEY=your-api-key-here

# Default model ID for openclaude
LOCAL_LLM_MODEL=Qwen/Qwen3-Coder-Next-FP8
